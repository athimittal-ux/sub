#include <stdio.h>

int main() {
    FILE *fp = fopen("data.csv", "w");

    if (fp == NULL) {
        printf("Error creating file!\n");
        return 1;
    }

    fprintf(fp, "Name,Age,Marks\n");
    fprintf(fp, "John,20,85\n");
    fprintf(fp, "Alice,22,90\n");

    fclose(fp);

    printf("CSV file created successfully!\n");
    return 0;
}
